# Environment variables for YOLO Safety Detection System
# Copy this file to .env and update values as needed

# Device Configuration
DEVICE=cuda  # Options: cuda, cpu, mps
HALF_PRECISION=true
NUM_WORKERS=4

# Model Configuration
WORKER_DETECTOR_PATH=models/yolo/worker_detector.pt
PPE_DETECTOR_PATH=models/yolo/ppe_detector.pt
DRONE_CLASSIFIER_PATH=models/yolo/drone_classifier.pt

# Inference Settings
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45
MAX_DETECTIONS=100

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Camera / Input Stream (optional)
# CAMERA_INDEX=0  # For USB camera
# RTSP_URL=rtsp://example.com/stream  # For IP camera

# Output
EXPORT_JSON=true
EXPORT_CSV=false
